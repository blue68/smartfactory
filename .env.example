# ─────────────────────────────────────────────────────────────────────────────
# 智造管家（SmartFactory Agent）环境变量配置模板
#
# 使用说明：
#   1. 复制本文件：cp .env.example .env
#   2. 修改 .env 中的所有 CHANGE_ME 占位值
#   3. 确保 .env 已加入 .gitignore，不要提交到代码仓库
#
# 密码生成建议：
#   openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────


# ── 应用基础配置 ──────────────────────────────────────────────────────────────

# 应用名称（显示在界面和日志中）
APP_NAME=智造管家

# Web 访问端口（默认 80，如有端口冲突可改为 8080 等）
WEB_PORT=80

# 日志级别：error | warn | info | debug
LOG_LEVEL=info

# 库存仓位校验阶段：A（灰度兜底）| B（仅盘点修复可兜底）| C（完全强校验）
INVENTORY_WAREHOUSE_PHASE=A


# ── MySQL 数据库 ──────────────────────────────────────────────────────────────

# MySQL root 密码（仅用于容器初始化，日常应用使用 DB_USER/DB_PASS）
# 请修改为强密码（建议 16 位以上，包含大小写字母、数字、符号）
DB_ROOT_PASSWORD=CHANGE_ME_root_password

# 应用数据库名称（默认无需修改）
DB_NAME=smart_factory

# 应用数据库用户名
DB_USER=sf_app

# 应用数据库密码（请修改为强密码）
DB_PASS=CHANGE_ME_db_password

# 数据库连接池大小（小型本地部署建议 6；如并发较高再调大）
DB_POOL_SIZE=6
DB_POOL_MAX=6


# ── 本地 Docker 资源保护 ─────────────────────────────────────────────────────

# 默认关闭 API 内部后台 Worker，避免本地启动后同时拉起队列消费者与定时任务。
# 需要消费异步任务/定时扫描时改为 true。
ENABLE_BACKGROUND_WORKERS=false

# Node API V8 堆上限；应小于 API_MEM_LIMIT。
NODE_OPTIONS=--max-old-space-size=256

# Docker Compose 运行期资源上限（普通 docker compose up 可直接生效）
MYSQL_MEM_LIMIT=512m
MYSQL_MEMSWAP_LIMIT=512m
MYSQL_CPUS=0.75
REDIS_MEM_LIMIT=160m
REDIS_MEMSWAP_LIMIT=160m
REDIS_CPUS=0.35
API_MEM_LIMIT=384m
API_MEMSWAP_LIMIT=384m
API_CPUS=0.75
WEB_MEM_LIMIT=96m
WEB_MEMSWAP_LIMIT=96m
WEB_CPUS=0.25


# ── Redis 缓存 ────────────────────────────────────────────────────────────────

# Redis 访问密码（请修改为强密码）
REDIS_PASSWORD=CHANGE_ME_redis_password


# ── JWT 认证 ──────────────────────────────────────────────────────────────────

# JWT 签名密钥（请修改为随机字符串，至少 32 位）
# 生成命令：openssl rand -base64 48
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_characters_long

# JWT Refresh Token 独立签名密钥（与 JWT_SECRET 不同，用于刷新令牌）
# 生成命令：openssl rand -base64 48
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_different_from_access

# JWT 令牌有效期（7d = 7天，可改为 24h / 30d 等）
JWT_EXPIRES_IN=7d


# ── CORS 跨域白名单（SEC-012）────────────────────────────────────────────────

# 允许跨域访问 API 的前端来源，多个地址用英文逗号分隔，不允许通配符 *。
# 生产环境示例：CORS_ORIGINS=https://app.example.com,https://admin.example.com
# 留空时自动退回开发默认值：
# http://localhost,http://localhost:80,http://localhost:3000,http://localhost:5173,
# http://127.0.0.1,http://127.0.0.1:80,http://127.0.0.1:3000,http://127.0.0.1:5173
CORS_ORIGINS=


# ── AI 引擎（Phase 2，暂时留空）──────────────────────────────────────────────

# AI 引擎内部地址（Phase 2 启用 Python FastAPI 服务时填写）
AI_ENGINE_URL=

# OpenAI API Key（如果使用 OpenAI 能力，填写此项）
OPENAI_API_KEY=


# ── 文件上传存储（本地 / 阿里云 OSS）─────────────────────────────────────────

# 本地测试建议使用 local；正式环境建议使用 oss。
FILE_STORAGE_DRIVER=local

# 本地文件存储目录（容器内路径）
UPLOAD_DIR=/app/uploads

# 阿里云 OSS 基础配置（仅 FILE_STORAGE_DRIVER=oss 时必填）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_PATH_PREFIX=smartfactory
