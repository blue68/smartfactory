page {
  min-height: 100%;
  background: #f3f7fc;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

button {
  border-radius: 18rpx;
}

button[disabled] {
  opacity: .58;
}

.page {
  padding: 28rpx 24rpx 44rpx;
  box-sizing: border-box;
}

.hero {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  color: #fff;
  background: linear-gradient(135deg, #095cc9 0%, #18a3d7 100%);
  box-shadow: 0 18rpx 42rpx rgba(15, 98, 214, .22);
}

.eyebrow {
  display: block;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, .78);
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.15;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, .82);
}

.ghost-button,
.scan-button {
  min-width: 128rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 28rpx;
  color: #0f62d6;
  background: #fff;
  font-weight: 700;
  font-size: 28rpx;
}

.metric-row {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0;
}

.metric-card {
  flex: 1;
  padding: 22rpx 18rpx;
  border-radius: 26rpx;
  background: #fff;
  box-shadow: 0 12rpx 34rpx rgba(30, 50, 80, .08);
}

.metric-value {
  display: block;
  min-height: 42rpx;
  color: #14213d;
  font-size: 34rpx;
  font-weight: 800;
  word-break: break-all;
}

.metric-label {
  display: block;
  margin-top: 6rpx;
  color: #77859a;
  font-size: 22rpx;
}

.section,
.task-card,
.alert-card,
.empty-card,
.sku-card,
.info-card {
  margin-top: 22rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(30, 50, 80, .07);
}

.section-title {
  display: block;
  margin-bottom: 20rpx;
  color: #16243a;
  font-size: 30rpx;
  font-weight: 800;
}

.input,
.textarea,
.picker-box {
  width: 100%;
  margin-top: 16rpx;
  padding: 0 22rpx;
  min-height: 84rpx;
  line-height: 84rpx;
  box-sizing: border-box;
  border: 2rpx solid #dfe8f5;
  border-radius: 20rpx;
  background: #f9fbff;
  color: #172033;
  font-size: 28rpx;
}

.textarea {
  min-height: 168rpx;
  line-height: 1.5;
  padding-top: 22rpx;
}

.field-help,
.muted {
  display: block;
  margin-top: 14rpx;
  color: #77859a;
  font-size: 24rpx;
  line-height: 1.5;
}

.inline-row,
.action-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.flex {
  flex: 1;
}

.primary-button,
.success-button,
.danger-button,
.submit-button,
.secondary-button,
.primary-small,
.alert-action,
.empty-action {
  margin-top: 20rpx;
  color: #fff;
  background: #0f62d6;
  font-weight: 800;
  font-size: 28rpx;
}

.success-button,
.submit-button {
  background: #0a9f62;
}

.danger-button {
  background: #d64545;
}

.secondary-button {
  color: #0f62d6;
  background: #eaf2ff;
}

.primary-small {
  min-width: 128rpx;
  margin-top: 16rpx;
}

.alert-card {
  border: 2rpx solid #ffd5d5;
  background: #fff7f7;
}

.alert-title {
  display: block;
  color: #c92a2a;
  font-weight: 800;
}

.alert-text {
  display: block;
  margin-top: 8rpx;
  color: #7b3540;
  font-size: 24rpx;
  line-height: 1.5;
}

.empty-card {
  text-align: center;
  color: #77859a;
}

.status-pill,
.count-pill,
.chip,
.quick-chip,
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #0f62d6;
  background: #eaf2ff;
  font-size: 24rpx;
  font-weight: 700;
}

.chips,
.quick-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 12rpx 0;
}

.task-header,
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.task-title,
.sku-code {
  color: #172033;
  font-size: 32rpx;
  font-weight: 800;
}

.quick-chip {
  min-width: 88rpx;
  background: #eef9f2;
  color: #0a9f62;
}

.danger-section {
  border-left: 8rpx solid #d64545;
}

.release-section {
  border-left: 8rpx solid #0a9f62;
}

.image-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
}

.image-item,
.image-add {
  width: 152rpx;
  height: 152rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: #eef4ff;
  position: relative;
}

.image {
  width: 152rpx;
  height: 152rpx;
}

.image-remove {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 42rpx;
  line-height: 42rpx;
  text-align: center;
  color: #fff;
  background: rgba(0, 0, 0, .45);
  font-size: 22rpx;
}

.image-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #0f62d6;
  font-weight: 700;
}
