.dashboard-page {
  padding-bottom: 48rpx;
}

.dashboard-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  padding: 34rpx 30rpx;
  border-radius: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #0f766e 0%, #2563eb 100%);
  box-shadow: 0 18rpx 44rpx rgba(37, 99, 235, .2);
}

.dashboard-hero__brand {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.dashboard-hero__copy {
  min-width: 0;
}

.sf-logo {
  position: relative;
  flex: none;
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .18);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .28);
  overflow: hidden;
}

.sf-logo__factory {
  position: absolute;
  left: 18rpx;
  bottom: 19rpx;
  width: 31rpx;
  height: 19rpx;
  border-radius: 5rpx 5rpx 7rpx 7rpx;
  background: #fff;
}

.sf-logo__factory::before {
  content: "";
  position: absolute;
  left: 0;
  top: -13rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 13rpx solid #fff;
}

.sf-logo__node {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border: 3rpx solid #a7f3d0;
  border-radius: 999rpx;
  background: #fff;
}

.sf-logo__node--a {
  top: 20rpx;
  right: 17rpx;
}

.sf-logo__node--b {
  right: 16rpx;
  bottom: 20rpx;
}

.sf-logo__line {
  position: absolute;
  right: 23rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .84);
}

.sf-logo__line--a {
  top: 32rpx;
  height: 12rpx;
}

.sf-logo__line--b {
  top: 43rpx;
  right: 30rpx;
  width: 16rpx;
  height: 4rpx;
}

.dashboard-hero__eyebrow {
  color: rgba(255, 255, 255, .74);
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.dashboard-hero__title {
  margin-top: 8rpx;
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.15;
}

.dashboard-hero__sub {
  display: block;
  max-width: 470rpx;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, .82);
  font-size: 24rpx;
  line-height: 1.45;
  word-break: break-all;
}

.dashboard-logout {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  height: 62rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #fff;
  background: rgba(255, 255, 255, .18);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}

.dashboard-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 22rpx -8rpx 0;
}

.dashboard-cell {
  width: 33.3333%;
  box-sizing: border-box;
  padding: 8rpx;
}

.dashboard-tile {
  min-height: 190rpx;
  box-sizing: border-box;
  padding: 22rpx 14rpx 18rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, .08);
}

.dashboard-tile__mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin: 0 auto 14rpx;
  border-radius: 18rpx;
  color: #fff;
  background: #2563eb;
  font-size: 28rpx;
  font-weight: 900;
}

.dashboard-tile--warehouseInbound .dashboard-tile__mark {
  background: #0f766e;
}

.dashboard-tile--qcInspect .dashboard-tile__mark {
  background: #7c3aed;
}

.dashboard-tile--stocktaking .dashboard-tile__mark {
  background: #ea580c;
}

.dashboard-tile__title {
  display: block;
  color: #172033;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.3;
  text-align: center;
}

.dashboard-tile__desc {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 21rpx;
  line-height: 1.35;
  text-align: center;
}
