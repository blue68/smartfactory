<view class="page">
  <view class="mini-page-nav">
    <view class="mini-page-nav__back" bindtap="handleBackToDashboard">
      <text class="mini-page-nav__icon">‹</text>
      <text>控制面板</text>
    </view>
    <text class="mini-page-nav__title">仓库入库</text>
  </view>

  <view class="scan-zone">
    <button class="scan-btn" bindtap="handleScan">
      <text class="scan-btn__icon">📷</text>
      <text>扫描物料条码</text>
    </button>
    <button class="shelf-btn" bindtap="handleShelfScan">
      <text>扫描仓库货架条码</text>
    </button>
    <view class="scan-search">
      <view class="scan-input-wrap">
        <input
          class="scan-input"
          value="{{keyword}}"
          placeholder="SKU 编码 / 名称"
          placeholder-class="mobile-placeholder"
          confirm-type="search"
          adjust-position="{{true}}"
          bindinput="handleKeywordInput"
          bindconfirm="handleSearchSubmit"
        />
        <view wx:if="{{hasKeyword}}" class="scan-input-clear" bindtap="clearKeyword">×</view>
      </view>
    </view>
    <view class="scan-actions">
      <button class="scan-query" loading="{{loading}}" disabled="{{queryDisabled}}" bindtap="handleSearchSubmit">查询</button>
      <button wx:if="{{canResetMock}}" class="stock-reset" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleResetMockData">重置数据</button>
    </view>
  </view>

  <view class="stock-brief">
    <view>
      <text class="stock-brief__label">仓库同步</text>
      <text class="stock-brief__value">{{syncLabel}}</text>
    </view>
    <view>
      <text class="stock-brief__label">候选物料</text>
      <text class="stock-brief__value">{{skuCandidateCount}}</text>
    </view>
  </view>

  <view class="stock-action-card">
    <text class="stock-action-card__label">当前上架检查</text>
    <view class="stock-action-card__summary">{{inboundSummary}}</view>
    <text class="stock-action-card__hint">{{inboundActionHint}}</text>
  </view>

  <view wx:if="{{loadError}}" class="alert-card">
    <text class="alert-title">仓库资料同步失败</text>
    <text class="alert-text">{{loadError}}</text>
    <button class="alert-action" bindtap="loadWarehouses">重试</button>
  </view>

  <view class="card">
    <view class="card__header">
      <text class="field-label">物料信息</text>
    </view>
    <view class="card__body">
      <picker mode="selector" range="{{skuRange}}" value="{{skuIdx}}" bindchange="handleSkuChange">
        <view class="stock-picker">{{skuPickerLabel}}</view>
      </picker>
      <view wx:if="{{selectedSkuLabel}}" class="sku-card">
        <button class="sku-card__change" bindtap="resetForm">更换</button>
        <text class="sku-code">{{selectedSkuCode}}</text>
        <text class="sku-name">{{selectedSkuName}}</text>
        <view class="sku-tags">
          <text class="tag tag--dye">缸号批次</text>
          <text class="tag tag--info">单位 {{selectedSkuUnit}}</text>
          <text class="tag tag--neutral">安全库存可查</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card__header">
      <text class="field-label">入库数量</text><text class="req">*</text>
    </view>
    <view class="card__body">
      <view wx:if="{{deliveryNo}}" class="delivery-hint">已识别送货单：{{deliveryNo}}</view>
      <view class="qty-stepper">
        <view class="{{qtyMinusClass}}" data-value="-1" bindtap="adjustQty">-</view>
        <input
          class="qty-stepper__input"
          type="digit"
          value="{{qty}}"
          placeholder="入库数"
          placeholder-class="mobile-placeholder"
          confirm-type="done"
          adjust-position="{{true}}"
          bindinput="handleQtyInput"
          bindconfirm="handleQtyConfirm"
        />
        <view class="qty-stepper__unit">{{selectedSkuUnit}}</view>
        <view class="qty-stepper__btn" data-value="1" bindtap="adjustQty">+</view>
      </view>
      <view class="quick-row">
        <view wx:for="{{quickQty}}" wx:key="item" class="quick-chip" data-value="{{item}}" bindtap="addQuickQty">+{{item}}</view>
        <view wx:if="{{hasQty}}" class="quick-chip quick-chip--clear" bindtap="clearQty">清空</view>
      </view>
    </view>
  </view>

  <view class="dye-card">
    <view class="dye-card__head">
      <text class="dye-card__icon">🎨</text>
      <text class="dye-card__title">缸号 / 染色批次</text>
      <text class="dye-card__req">建议填写</text>
    </view>
    <input class="dye-input" value="{{dyeLotNo}}" placeholder="例如 DY-2026-001" placeholder-class="mobile-placeholder" confirm-type="done" adjust-position="{{true}}" bindinput="handleDyeLotInput" />
    <text class="dye-hint">同一订单面料建议保持同一缸号，避免色差追溯困难。</text>
  </view>

  <view class="card">
    <view class="card__header">
      <text class="field-label">上架库位</text><text class="req">*</text>
    </view>
    <view class="card__body">
      <picker mode="selector" range="{{warehouseRange}}" value="{{warehouseIdx}}" bindchange="handleWarehouseChange">
        <view class="stock-picker">{{warehousePickerLabel}}</view>
      </picker>
      <picker mode="selector" range="{{locationRange}}" value="{{locationIdx}}" bindchange="handleLocationChange">
        <view class="stock-picker">{{locationPickerLabel}}</view>
      </picker>
    </view>
  </view>

  <view class="stock-footer">
    <button class="stock-clear" disabled="{{submitting}}" bindtap="resetForm">清空</button>
    <button class="confirm-btn" loading="{{submitting}}" disabled="{{submitDisabled}}" bindtap="handleSubmit">确认入库</button>
  </view>

  <view wx:if="{{successVisible}}" class="success-layer">
    <view class="success-icon">✅</view>
    <view class="success-title">入库成功</view>
    <view class="success-card">
      <view class="srow"><text>物料</text><text>{{successSkuLabel}}</text></view>
      <view class="srow"><text>入库数量</text><text class="srow__big">{{successQtyLabel}}</text></view>
      <view class="srow"><text>缸号批次</text><text>{{successDyeLot}}</text></view>
    </view>
    <button class="success-next" bindtap="closeSuccess">继续入库</button>
  </view>
</view>
