.page {
  padding-bottom: 64rpx;
}

.stocktaking-hero {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 34rpx 30rpx;
  border-radius: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #0f766e 0%, #2563eb 100%);
  box-shadow: 0 18rpx 44rpx rgba(15, 118, 110, .2);
}

.stocktaking-hero__eyebrow {
  display: block;
  margin-bottom: 8rpx;
  color: rgba(255, 255, 255, .72);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.stocktaking-hero__title {
  color: #fff;
  font-size: 42rpx;
  font-weight: 800;
}

.stocktaking-hero__sub {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, .8);
  font-size: 24rpx;
  line-height: 1.45;
}

.stocktaking-hero__stat {
  flex: none;
  min-width: 128rpx;
  align-self: flex-start;
  padding: 14rpx 18rpx;
  border-radius: 22rpx;
  text-align: center;
  background: rgba(255, 255, 255, .18);
}

.stocktaking-hero__stat text {
  display: block;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.stocktaking-panel,
.stocktaking-receipt,
.stocktaking-summary {
  margin-top: 22rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: #fff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, .08);
}

.stocktaking-panel__title {
  color: #1e293b;
  font-size: 30rpx;
  font-weight: 800;
}

.stocktaking-actions,
.stocktaking-search,
.stocktaking-submit-row {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.stocktaking-tool,
.stocktaking-search__btn,
.stocktaking-primary,
.stocktaking-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 84rpx;
  line-height: 1;
  padding: 0 18rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
}

.stocktaking-tool {
  flex: 1;
  color: #2563eb;
  background: #eff6ff;
}

.stocktaking-tool--scan {
  color: #0f766e;
  background: #ccfbf1;
}

.stocktaking-tool--reset {
  color: #ea580c;
  background: #fff7ed;
}

.stocktaking-task {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 16rpx;
  padding: 20rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  background: #f8fafc;
}

.stocktaking-task--active {
  border-color: #2563eb;
  background: #eff6ff;
}

.stocktaking-task__title,
.stocktaking-task__meta,
.stocktaking-task__side text {
  display: block;
}

.stocktaking-task__title {
  color: #1e293b;
  font-size: 28rpx;
  font-weight: 800;
}

.stocktaking-task__meta {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
}

.stocktaking-task__side {
  flex: none;
  min-width: 110rpx;
  text-align: right;
  color: #2563eb;
  font-size: 23rpx;
  font-weight: 800;
}

.stocktaking-picker {
  min-height: 84rpx;
  line-height: 84rpx;
  margin-top: 16rpx;
  padding: 0 22rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  color: #1e293b;
  background: #f8fafc;
  font-size: 28rpx;
}

.stocktaking-primary,
.stocktaking-secondary {
  flex: 1;
  margin-top: 20rpx;
}

.stocktaking-primary {
  color: #fff;
  background: #2563eb;
}

.stocktaking-secondary {
  color: #0f766e;
  background: #ccfbf1;
}

.stocktaking-receipt {
  border: 2rpx solid #bfdbfe;
  background: linear-gradient(135deg, #eff6ff 0%, #fff 100%);
}

.stocktaking-receipt__label,
.stocktaking-receipt__title,
.stocktaking-receipt__text {
  display: block;
}

.stocktaking-receipt__label {
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 800;
}

.stocktaking-receipt__title {
  margin-top: 6rpx;
  color: #1e293b;
  font-size: 30rpx;
  font-weight: 800;
}

.stocktaking-receipt__text {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
}

.stocktaking-summary {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.stocktaking-summary__label {
  color: #64748b;
  font-size: 23rpx;
}

.stocktaking-summary__title {
  color: #1e293b;
  font-size: 30rpx;
  font-weight: 800;
}

.stocktaking-summary__status {
  flex: none;
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #0f766e;
  background: #ccfbf1;
  font-size: 24rpx;
  font-weight: 800;
}

.stocktaking-search__input {
  flex: 1;
  min-width: 0;
  margin-top: 0;
}

.stocktaking-search__btn {
  flex: none;
  width: 144rpx;
  color: #2563eb;
  background: #eff6ff;
}

.stocktaking-kpis {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.stocktaking-kpis view {
  flex: 1;
  padding: 18rpx;
  border-radius: 18rpx;
  text-align: center;
  background: #f8fafc;
}

.stocktaking-kpis text {
  display: block;
  color: #64748b;
  font-size: 22rpx;
}

.stocktaking-kpis__num {
  color: #1e293b;
  font-size: 34rpx;
  font-weight: 800;
}

.stocktaking-item {
  margin-top: 18rpx;
  padding: 22rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 22rpx;
  background: #fff;
}

.stocktaking-item__head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.stocktaking-item__code,
.stocktaking-item__name,
.stocktaking-item__meta {
  display: block;
}

.stocktaking-item__code {
  color: #1e293b;
  font-size: 28rpx;
  font-weight: 800;
}

.stocktaking-item__name,
.stocktaking-item__meta {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
}

.stocktaking-item__diff {
  flex: none;
  align-self: flex-start;
  color: #16a34a;
  font-size: 24rpx;
  font-weight: 800;
}

.stocktaking-item__diff--warn {
  color: #ea580c;
}

.stocktaking-item__input {
  width: 100%;
  height: 92rpx;
  margin-top: 16rpx;
  border: 4rpx solid #e2e8f0;
  border-radius: 20rpx;
  text-align: center;
  color: #0f172a;
  background: #fff;
  font-size: 42rpx;
  font-weight: 800;
}
