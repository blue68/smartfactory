<view class="page">
  <view class="mini-page-nav">
    <view class="mini-page-nav__back" bindtap="handleBackToDashboard">
      <text class="mini-page-nav__icon">‹</text>
      <text>控制面板</text>
    </view>
    <text class="mini-page-nav__title">QC检验</text>
    <text class="qc-nav__step">{{pendingCount}} / {{draftCountLabel}} 待检</text>
  </view>

  <view class="unit-bar">
    <view>
      <text class="unit-bar__order">{{unitOrderLabel}} · {{unitPurchaseLabel}}</text>
      <view class="unit-bar__product">{{unitProductLabel}}</view>
      <view class="unit-bar__tags">
        <text>最后同步 {{syncLabel}}</text>
        <text>{{overallResultLabel}}</text>
        <text>{{inspectionStatusLabel}}</text>
      </view>
    </view>
    <view class="unit-bar__progress">
      <text class="unit-bar__progress-num">{{completedItemCount}}</text>
      <text class="unit-bar__progress-label">已判定</text>
    </view>
  </view>

  <view class="progress-track">
    <view class="progress-track__fill" style="{{progressStyle}}"></view>
  </view>

  <view class="qc-receipt">
    <text class="qc-receipt__label">最近质检动作</text>
    <view class="qc-receipt__title">{{latestOperationTitle}}</view>
    <text class="qc-receipt__text">{{latestOperationText}}</text>
  </view>

  <view class="qc-flow-hint">{{qcFlowHint}}</view>

  <view wx:if="{{loadError}}" class="alert-card">
    <text class="alert-title">质检任务同步失败</text>
    <text class="alert-text">{{loadError}}</text>
    <button class="alert-action" bindtap="loadInspections">重试</button>
  </view>

  <view class="qc-card">
    <text class="qc-label">选择质检单</text>
    <picker mode="selector" range="{{inspectionRange}}" value="{{inspectionIdx}}" bindchange="handleInspectionChange">
      <view class="qc-picker">{{inspectionPickerLabel}}</view>
    </picker>
    <button class="qc-refresh" loading="{{loading}}" disabled="{{loading}}" bindtap="loadInspections">刷新质检列表</button>
    <button wx:if="{{canResetMock}}" class="qc-reset" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleResetMockData">重置数据</button>
  </view>

  <block wx:if="{{hasActiveDraft}}">
    <view class="section-label">逐件检验</view>
    <button class="quick-pass" disabled="{{quickPassDisabled}}" bindtap="markAllPass">一键全部合格</button>
    <view wx:if="{{inspectionSubmitted}}" class="qc-lock">该质检单已提交，当前页面只读。</view>
    <view wx:for="{{draftCards}}" wx:key="index" class="{{item.cardClass}}">
      <view class="inspect-card__header" data-index="{{index}}" bindtap="handleActiveItemChange">
        <view class="inspect-card__num">{{item.marker}}</view>
        <view class="inspect-card__info">
          <text class="inspect-card__name">{{item.label}}</text>
          <text class="inspect-card__desc">{{item.desc}}</text>
        </view>
        <text class="inspect-card__status status--{{item.state}}">{{item.badge}}</text>
      </view>
      <view class="inspect-btns">
        <button class="{{item.passButtonClass}}" data-index="{{index}}" bindtap="markDraftPass">✓ 合格</button>
        <button class="{{item.failButtonClass}}" data-index="{{index}}" bindtap="markDraftFail">× 不合格</button>
      </view>
    </view>

    <view class="defect-form">
      <view class="defect-form__title">当前明细补充信息</view>
      <picker mode="selector" range="{{draftRange}}" value="{{activeItemIdx}}" bindchange="handleActiveItemChange">
        <view class="qc-picker">{{activeLabel}}</view>
      </picker>
      <input class="input" type="digit" value="{{activeQtyDelivered}}" placeholder="送货数" data-field="qtyDelivered" bindinput="handleDraftInput" />
      <input class="input" type="digit" value="{{activeQtySampled}}" placeholder="抽检数" data-field="qtySampled" bindinput="handleDraftInput" />
      <input class="input" type="digit" value="{{activeQtyPassed}}" placeholder="合格数" data-field="qtyPassed" bindinput="handleDraftInput" />
      <input class="input" type="digit" value="{{activeQtyFailed}}" placeholder="不良数" data-field="qtyFailed" bindinput="handleDraftInput" />
      <input class="input" type="digit" value="{{activeAcceptedStockQty}}" placeholder="接收入库数" data-field="acceptedStockQty" bindinput="handleDraftInput" />
      <input class="input" value="{{activeDyeLotNo}}" placeholder="缸号/批号，可选" data-field="dyeLotNo" bindinput="handleDraftTextInput" />
      <picker mode="selector" range="{{resultLabels}}" value="{{activeResultIdx}}" bindchange="handleDraftResultChange">
        <view class="qc-picker">结果：{{activeResultPickerLabel}}</view>
      </picker>
      <picker mode="selector" range="{{dispositionLabels}}" value="{{activeDispositionIdx}}" bindchange="handleDraftDispositionChange">
        <view class="qc-picker">处置：{{activeDispositionPickerLabel}}</view>
      </picker>
      <textarea class="textarea" value="{{activeNotes}}" placeholder="明细备注，可选" maxlength="300" data-field="notes" bindinput="handleDraftTextInput" />
      <text class="field-help">抽检数必须覆盖合格数和不良数，留证图最多 3 张。</text>
      <view class="image-row">
        <view wx:for="{{activeDefectImages}}" wx:key="item" class="image-item" data-url="{{item}}" bindtap="removeImage">
          <image class="image" src="{{item}}" mode="aspectFill" />
          <text class="image-remove">移除</text>
        </view>
        <view class="image-add" bindtap="uploadImages">
          <text>+</text>
          <text>{{uploadText}}</text>
        </view>
      </view>
    </view>

    <view class="summary-card">
      <view class="summary-card__title">检验汇总</view>
      <view class="summary-stats">
        <view><text class="summary-stats__num">{{draftCountLabel}}</text><text class="summary-stats__label">总数</text></view>
        <view><text class="summary-stats__num">{{completedItemCount}}</text><text class="summary-stats__label">已判定</text></view>
        <view><text class="summary-stats__num">{{pendingCount}}</text><text class="summary-stats__label">待检</text></view>
      </view>
    </view>

    <view class="release-panel">
      <text class="section-title">放行入库</text>
      <picker mode="selector" range="{{resultLabels}}" value="{{overallResultIdx}}" bindchange="handleOverallResultChange">
        <view class="qc-picker">总结果：{{overallResultLabel}}</view>
      </picker>
      <picker mode="selector" range="{{warehouseRange}}" value="{{warehouseIdx}}" bindchange="handleWarehouseChange">
        <view class="qc-picker">{{warehousePickerLabel}}</view>
      </picker>
      <picker mode="selector" range="{{locationRange}}" value="{{locationIdx}}" bindchange="handleLocationChange">
        <view class="qc-picker">{{locationPickerLabel}}</view>
      </picker>
      <textarea class="textarea" value="{{notes}}" placeholder="质检备注，可选" maxlength="500" bindinput="handleNotesInput" />
      <text class="field-help">{{saveHint}}</text>
      <text class="field-help">{{submitHint}}</text>
      <view class="action-row">
        <button class="qc-outline flex" loading="{{submitting}}" disabled="{{saveDisabled}}" bindtap="handleSave">保存明细</button>
        <button class="qc-submit flex" loading="{{submitting}}" disabled="{{submitDisabled}}" bindtap="handleSubmit">{{submitButtonText}}</button>
      </view>
    </view>

    <view wx:if="{{hasOperationLogs}}" class="summary-card">
      <view class="summary-card__title">质检回执</view>
      <view wx:for="{{operationLogs}}" wx:key="id" class="qc-log">
        <text class="qc-log__time">{{item.time}}</text>
        <view class="qc-log__body">
          <text class="qc-log__title">{{item.title}}</text>
          <text class="qc-log__text">{{item.content}}</text>
        </view>
      </view>
    </view>
  </block>

  <view wx:else class="empty-card">
    <text>{{emptyText}}</text>
    <button wx:if="{{showRetry}}" class="empty-action" bindtap="loadInspections">重新同步</button>
  </view>
</view>
