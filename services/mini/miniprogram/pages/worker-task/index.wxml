<view class="page">
  <view class="ops-hero">
    <view class="ops-hero__main">
      <text class="ops-hero__eyebrow">PRODUCTION TASK</text>
      <view class="ops-hero__title">我的任务</view>
      <text class="ops-hero__sub">{{lastRefreshAt ? '最后同步 ' + lastRefreshAt : '扫码或下拉刷新任务'}}</text>
    </view>
    <view class="ops-hero__stat">
      <text class="ops-hero__num">{{activeTaskCount}}</text>
      <text class="ops-hero__label">待完成</text>
    </view>
  </view>

  <view wx:if="{{loadError}}" class="alert-card">
    <text class="alert-title">任务同步失败</text>
    <text class="alert-text">{{loadError}}</text>
    <button class="alert-action" bindtap="loadTasks">重试</button>
  </view>

  <view class="ops-toolbar">
    <picker class="ops-toolbar__picker" mode="selector" range="{{statusOptions}}" value="{{statusIdx}}" bindchange="handleStatusChange">
      <view class="ops-filter">状态：{{statusOptions[statusIdx]}}</view>
    </picker>
    <button class="ops-scan" bindtap="handleScanTask">扫码</button>
    <button class="ops-refresh" loading="{{loading}}" disabled="{{loading}}" bindtap="loadTasks">刷新</button>
  </view>

  <view class="ops-section-head">
    <text class="ops-section-head__title">任务列表</text>
    <text class="ops-section-head__count">{{tasks.length}} 个</text>
  </view>

  <view wx:for="{{taskCards}}" wx:key="id" class="ops-task ops-task--{{item.priority}} {{item.active ? 'ops-task--active' : ''}}" data-index="{{index}}" bindtap="handleTaskChange">
    <view class="ops-task__bar"></view>
    <view class="ops-task__body">
      <view class="ops-task__top">
        <text class="ops-task__priority">{{item.priorityLabel}}</text>
        <text class="ops-task__name">{{item.title}}</text>
        <text class="ops-task__dot ops-task__dot--{{item.status}}"></text>
      </view>
      <view class="ops-task__meta">
        <view>
          <text class="ops-task__label">订单号</text>
          <text class="ops-task__value">{{item.orderNo}}</text>
        </view>
        <view>
          <text class="ops-task__label">产品</text>
          <text class="ops-task__value">{{item.sku}}</text>
        </view>
        <view>
          <text class="ops-task__label">进度</text>
          <text class="ops-task__value">{{item.qty}}</text>
        </view>
      </view>
      <view wx:if="{{item.active}}" class="ops-task__selected">当前操作任务 · {{item.statusLabel}}</view>
    </view>
  </view>

  <block wx:if="{{selectedTask}}">
    <view class="ops-panel">
      <view class="ops-panel__header">
        <view>
          <text class="ops-panel__kicker">当前工序</text>
          <view class="ops-panel__title">{{taskTitle}}</view>
        </view>
        <text class="status-pill status-{{selectedTask.status}}">{{taskStatusLabel}}</text>
      </view>
      <text class="muted">{{taskSkuLabel}} · 计划 {{selectedTask.plannedQty || '-'}} {{selectedTask.unit || ''}}</text>
      <button class="ops-primary" loading="{{submitting}}" disabled="{{submitting || selectedTask.status === 'completed'}}" bindtap="handleStart">确认开工</button>
    </view>

    <view class="ops-panel">
      <text class="ops-panel__title">所需物料 / 投料</text>
      <view class="material-stack">
        <view wx:for="{{inputMaterialViews}}" wx:key="key" class="material-line" data-index="{{index}}" bindtap="pickRecommendedMaterial">
          {{item.label}}
        </view>
      </view>
      <view wx:if="{{inputMaterialViews.length === 0}}" class="ops-empty">暂无 BOM 推荐投料，可手动搜索 SKU。</view>
      <view class="inline-row">
        <input class="input flex" value="{{materialKeyword}}" placeholder="物料编码/名称" bindinput="handleMaterialKeywordInput" />
        <button class="primary-small" loading="{{materialSearching}}" disabled="{{materialSearching}}" bindtap="searchMaterial">查询</button>
      </view>
      <picker mode="selector" range="{{materialRange}}" value="{{materialIdx}}" bindchange="handleMaterialChange">
        <view class="picker-box">{{selectedMaterialLabel || '请选择投料物料'}}</view>
      </picker>
      <input class="input" type="digit" value="{{issueQty}}" placeholder="投料数量" bindinput="handleIssueQtyInput" />
      <input class="input" value="{{dyeLotNo}}" placeholder="缸号/批号，可选" bindinput="handleDyeLotInput" />
      <picker mode="selector" range="{{warehouseRange}}" value="{{warehouseIdx}}" bindchange="handleWarehouseChange">
        <view class="picker-box">{{selectedWarehouseLabel || '请选择出库仓库'}}</view>
      </picker>
      <picker mode="selector" range="{{locationRange}}" value="{{locationIdx}}" bindchange="handleLocationChange">
        <view class="picker-box">{{selectedLocationLabel || '请选择库位，可选'}}</view>
      </picker>
      <text class="field-help">投料会写入当前任务领料记录，请核对 SKU、数量和库位。</text>
      <button class="ops-primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleIssue">确认投料</button>
    </view>

    <view class="ops-panel">
      <text class="ops-panel__title">完工报工</text>
      <input class="input" type="digit" value="{{completedQty}}" placeholder="完工数量" bindinput="handleCompletedQtyInput" />
      <input class="input" type="digit" value="{{actualHours}}" placeholder="实际工时(h)，支持小数" bindinput="handleActualHoursInput" />
      <input class="input" type="digit" value="{{scrapQty}}" placeholder="报废数量，可选" bindinput="handleScrapQtyInput" />
      <textarea class="textarea" value="{{completeNotes}}" placeholder="完工备注，可选" maxlength="300" bindinput="handleCompleteNotesInput" />
      <button class="ops-success" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleComplete">提交完工</button>
    </view>

    <view class="ops-panel ops-panel--danger">
      <text class="ops-panel__title">异常上报</text>
      <picker mode="selector" range="{{exceptionLabels}}" value="{{exceptionTypeIdx}}" bindchange="handleExceptionTypeChange">
        <view class="picker-box">异常类型：{{exceptionLabels[exceptionTypeIdx]}}</view>
      </picker>
      <picker mode="selector" range="{{severityLabels}}" value="{{severityIdx}}" bindchange="handleSeverityChange">
        <view class="picker-box">严重程度：{{severityLabels[severityIdx]}}</view>
      </picker>
      <textarea class="textarea" value="{{exceptionText}}" placeholder="描述异常现象、影响范围和需要支持的事项" maxlength="500" bindinput="handleExceptionTextInput" />
      <button class="ops-warning" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleException">立即上报</button>
    </view>
  </block>

  <view wx:else class="empty-card">
    <text>{{loading ? '任务加载中...' : '暂无符合条件的任务'}}</text>
    <button wx:if="{{!loading}}" class="empty-action" bindtap="loadTasks">重新同步</button>
  </view>
</view>
