.login-page {
  display: flex;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 56rpx 30rpx 48rpx;
  background: linear-gradient(180deg, #eaf3ff 0%, #f8fafc 58%, #ffffff 100%);
}

.login-shell {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.login-brand {
  margin-bottom: 30rpx;
  padding: 0 8rpx;
}

.login-brand__eyebrow {
  color: #2563eb;
  font-size: 23rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.login-brand__title {
  margin-top: 10rpx;
  color: #172033;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.15;
}

.login-brand__sub {
  display: block;
  margin-top: 12rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.45;
}

.login-card {
  padding: 34rpx 30rpx;
  border-radius: 30rpx;
  background: #fff;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, .1);
}

.login-field {
  margin-bottom: 22rpx;
}

.login-label {
  display: block;
  margin-bottom: 10rpx;
  color: #334155;
  font-size: 25rpx;
  font-weight: 800;
}

.login-input {
  width: 100%;
  height: 94rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border: 2rpx solid #dbe7f5;
  border-radius: 22rpx;
  color: #172033;
  background: #f8fbff;
  font-size: 30rpx;
}

.login-hint {
  display: block;
  min-height: 36rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
}

.login-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  margin-top: 26rpx;
  border-radius: 24rpx;
  color: #fff;
  background: #2563eb;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
}
