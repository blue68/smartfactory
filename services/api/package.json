{
  "name": "smart-factory-api",
  "version": "1.0.0",
  "description": "智造管家 API 服务",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest tests/unit/ --forceExit",
    "test:unit:outsource-flow": "jest tests/unit/production-phase1.service.test.ts tests/unit/scheduler.phase2.operations.test.ts tests/unit/incomingInspection.regression.test.ts tests/unit/purchaseSuggestion.regression.test.ts tests/unit/purchaseOrder.regression.test.ts --runInBand --forceExit --detectOpenHandles",
    "test:unit:access-control": "jest tests/unit/accessControl.auth.test.ts tests/unit/auth.service.permission.test.ts --runInBand --forceExit",
    "test:integration": "jest tests/integration/ --forceExit --detectOpenHandles",
    "test:integration:incoming-inspection": "jest tests/integration/incomingInspection.api.test.ts --runInBand --forceExit --detectOpenHandles",
    "test:integration:consumable-asset": "jest tests/integration/consumableAsset.api.test.ts --runInBand --forceExit --detectOpenHandles",
    "test:integration:access-control": "jest tests/integration/accessControl.api.test.ts --runInBand --forceExit --detectOpenHandles",
    "test:integration:managed": "TEST_DEFAULT_TARGET=tests/integration/ bash ../../scripts/run-api-integration.sh",
    "test:integration:incoming-inspection:managed": "TEST_DEFAULT_TARGET=tests/integration/incomingInspection.api.test.ts bash ../../scripts/run-api-integration.sh",
    "test:integration:consumable-asset:managed": "TEST_DEFAULT_TARGET=tests/integration/consumableAsset.api.test.ts bash ../../scripts/run-api-integration.sh",
    "test:outsource-flow:managed": "bash ../../scripts/run-api-integration.sh tests/integration/incomingInspection.api.test.ts",
    "test:integration:access-control:managed": "TEST_DEFAULT_TARGET=tests/integration/accessControl.api.test.ts bash ../../scripts/run-api-integration.sh",
    "test:integration:local": "UPLOAD_DIR=/tmp/uploads jest --testPathPattern=tests/integration/.*\\.local\\.test\\.ts$ --runInBand --forceExit",
    "test:e2e": "jest tests/e2e/ --forceExit --detectOpenHandles --testTimeout=60000",
    "test:e2e:managed": "TEST_DEFAULT_TARGET=tests/e2e/ TEST_TIMEOUT_MS=90000 bash ../../scripts/run-api-integration.sh",
    "test:coverage": "jest tests/unit/ --coverage --forceExit"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bull": "^4.16.0",
    "bullmq": "^5.71.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "decimal.js": "^10.4.3",
    "express": "^4.18.3",
    "express-rate-limit": "^7.4.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.9.3",
    "typeorm": "^0.3.20",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bull": "^4.10.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.30",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}
